{
  "name": "coc-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "coverage:check": "hardhat coverage && node scripts/check-coverage.cjs",
    "deploy:pose": "node --experimental-strip-types deploy/cli-deploy-pose.ts",
    "deploy:pose:coc": "node --experimental-strip-types deploy/cli-deploy-pose.ts --target l2-coc",
    "deploy:local": "npm run deploy:pose:coc",
    "deploy:governance:coc": "hardhat run scripts/deploy-governance.js --network coc",
    "deploy:governance": "hardhat run scripts/deploy-governance.js --network prowl",
    "deploy:governance:local": "hardhat run scripts/deploy-governance.js --network hardhat"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "chai": "^4.5.0",
    "ethers": "^6.13.5",
    "hardhat": "^2.22.18",
    "hardhat-gas-reporter": "^2.2.1",
    "solidity-coverage": "^0.8.13"
  }
}
