# Phase N1 — systemd EnvironmentFile for native validator instance 3.
# Deployed to /etc/coc/node-3.env (referenced by coc-node@3.service).

COC_DATA_DIR=/var/lib/coc/node-3
COC_NODE_CONFIG=/etc/coc/node-3.json
COC_NODE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Port bundle: identical to current docker host-side mapping
# (28784/28785/29784/29785/9103). Same IPFS-port note as node-2.
COC_RPC_BIND=0.0.0.0
COC_RPC_PORT=28784
COC_WS_BIND=0.0.0.0
COC_WS_PORT=28785
COC_P2P_BIND=0.0.0.0
COC_P2P_PORT=29784
COC_WIRE_BIND=0.0.0.0
COC_WIRE_PORT=29785
COC_METRICS_PORT=9103

COC_DEV_RELAXED_QUORUM=1
COC_BFT_AUTO_RECOVERY=1
COC_DIAG_SPEC_ROOT=0

COC_NODE_MODE=archive
COC_IPFS_PORT=5003
COC_IPFS_BIND=127.0.0.1
