# Phase N1 — systemd EnvironmentFile for native validator instance 2.
# Deployed to /etc/coc/node-2.env (referenced by coc-node@2.service).

COC_DATA_DIR=/var/lib/coc/node-2
COC_NODE_CONFIG=/etc/coc/node-2.json
COC_NODE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Port bundle: +2 offset from node-1 (each port pair stride 2 to leave room
# for matching ws/wire siblings). Same offset scheme as start-devnet.sh.
COC_RPC_BIND=0.0.0.0
COC_RPC_PORT=18782
COC_WS_BIND=0.0.0.0
COC_WS_PORT=18783
COC_P2P_BIND=0.0.0.0
COC_P2P_PORT=19782
COC_WIRE_BIND=0.0.0.0
COC_WIRE_PORT=19783
COC_IPFS_BIND=0.0.0.0
COC_IPFS_PORT=5002
COC_METRICS_PORT=9102

COC_DEV_RELAXED_QUORUM=0
COC_BFT_AUTO_RECOVERY=1
COC_DIAG_SPEC_ROOT=0

COC_NODE_MODE=archive
