# Phase N1 — systemd EnvironmentFile for native validator instance 1.
# Deployed to /etc/coc/node-1.env (referenced by coc-node@1.service).

COC_DATA_DIR=/var/lib/coc/node-1
COC_NODE_CONFIG=/etc/coc/node-1.json
# Replace with this validator's private key during deployment.
COC_NODE_KEY=REPLACE_WITH_NODE_1_PRIVATE_KEY

# Port bundle: KEEP the canonical external ports identical to the docker
# host-side mapping in docker-compose.testnet.yml (28780/28781/29780/29781/
# 28786/9101). External clients, sync-node (18780 retained on its docker
# container), relayer, agent, faucet, explorer, and any operator scripts
# stay pointed at the same numbers — the migration is transparent.
COC_RPC_BIND=0.0.0.0
COC_RPC_PORT=28780
COC_WS_BIND=0.0.0.0
COC_WS_PORT=28781
COC_P2P_BIND=0.0.0.0
COC_P2P_PORT=29780
COC_WIRE_BIND=0.0.0.0
COC_WIRE_PORT=29781
COC_IPFS_BIND=127.0.0.1
COC_IPFS_PORT=28786
COC_METRICS_PORT=9101

# Phase J/M tuning carried over from docker-compose.testnet.yml.
COC_DEV_RELAXED_QUORUM=1
COC_BFT_AUTO_RECOVERY=1
COC_DIAG_SPEC_ROOT=0

# Archive mode = 50G core node retention; never prune.
COC_NODE_MODE=archive
