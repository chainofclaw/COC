# scripts/gcloud/config.env — operator-local config for the 5-fullnode gcloud
# testnet. Copy to config.env and fill in. Sourced by every gcloud/*.sh script.
#
# This file is GIT-IGNORED — it contains your project ID and any IAM bindings
# you don't want to commit.

# ---- GCP project / network ----
export COC_GCP_PROJECT="your-gcp-project-id"
export COC_GCP_NETWORK="coc-testnet"           # VPC name created by 00-bootstrap-project.sh
export COC_GCP_SUBNET="coc-testnet-subnet"     # primary subnet (us-central1)
export COC_GCP_OPERATOR_IP_CIDR="0.0.0.0/0"    # SSH source range — narrow this for security

# ---- Image / labels ----
export COC_VM_IMAGE_FAMILY="ubuntu-2204-lts"
export COC_VM_IMAGE_PROJECT="ubuntu-os-cloud"
export COC_VM_LABELS="role=coc-fullnode,env=testnet,owner=$USER"

# ---- Per-node placement (zones, machine types) ----
export COC_ANCHOR_1_ZONE="us-central1-a"
export COC_ANCHOR_1_NAME="coc-anchor-1"
export COC_ANCHOR_1_TYPE="e2-standard-2"

export COC_ANCHOR_2_ZONE="asia-east1-a"
export COC_ANCHOR_2_NAME="coc-anchor-2"
export COC_ANCHOR_2_TYPE="e2-standard-2"

export COC_BURST_1_ZONE="europe-west1-b"
export COC_BURST_1_NAME="coc-burst-1"
export COC_BURST_1_TYPE="e2-medium"

export COC_BURST_2_ZONE="us-west1-a"
export COC_BURST_2_NAME="coc-burst-2"
export COC_BURST_2_TYPE="e2-medium"

export COC_BURST_3_ZONE="asia-southeast1-a"
export COC_BURST_3_NAME="coc-burst-3"
export COC_BURST_3_TYPE="e2-medium"

# ---- Disk ----
export COC_BOOT_DISK_SIZE_ANCHOR="50GB"
export COC_BOOT_DISK_SIZE_BURST="30GB"
export COC_BOOT_DISK_TYPE="pd-ssd"

# ---- Existing testnet (for joining) ----
# Set these from your operating knowledge of the running 3-validator testnet.
# Format: <validator_addr>:<host_or_public_ip>:<p2p_port>:<wire_port>
export COC_UPSTREAM_VALIDATORS=(
  "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266:209.74.64.88:29780:29781"
  "0x70997970C51812dc3A010C7d01b50e0d17dc79C8:159.198.44.136:29780:29781"
  "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC:199.192.16.79:49780:49781"
)
export COC_UPSTREAM_CHAIN_ID="18780"
export COC_UPSTREAM_RPC_URL="http://209.74.64.88:28780"   # used by anchor-stake-register.sh

# ---- Repo override (if testing a fork or branch) ----
export COC_REPO_URL="https://github.com/chainofclaw/COC.git"
export COC_REPO_REF="main"
