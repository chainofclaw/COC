    "poseProtocol": {
      "title": "PoSe协议详解",
      "challengeFlow": "挑战-响应流程",
      "step1": {
        "title": "挑战生成",
        "description": "Challenger根据VRF随机性选择目标节点,生成挑战消息",
        "details": ["challenge_id = keccak(epoch_id || node_id || type || nonce || challenger_id)", "包含查询规范 (U: RPC方法, S: chunk_id, R: route_tag)", "Challenger签名确保不可伪造"]
      },
      "step2": {
        "title": "节点响应",
        "description": "节点收到挑战后,在超时前生成响应并签名",
        "details": ["U挑战: 执行RPC查询,返回结果 (2.5s超时)", "S挑战: 提供存储证明 (Merkle路径, 6s超时)", "R挑战: 提交中继见证 (可选)"]
      },
      "step3": {
        "title": "收据验证",
        "description": "Aggregator或Verifier验证收据的有效性",
        "details": ["验证签名 (challenger + node)", "检查challenge_id唯一性", "验证响应内容 (U: 可重算, S: Merkle验证)"]
      },
      "step4": {
        "title": "链上提交",
        "description": "Aggregator将收据Merkle树根提交到链上",
        "details": ["提交 epoch_id + merkle_root + summary_hash", "包含k个随机样本收据 (k=32-128)", "开启2个epoch的争议窗口"]
      },
      "step5": {
        "title": "分数结算",
        "description": "Epoch结束后,根据通过率计算节点分数并分配奖励",
        "details": ["计算 S_u, S_s, S_r 分数", "应用收益递减和软上限", "分配到节点钱包"]
      },
      "scoringTitle": "评分公式详解",
      "uptimeScore": {
        "title": "正常运行时间分数",
        "formula": "S_u,i = u_i × (0.85 + 0.15 × lat_i)",
